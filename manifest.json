{
  "key": "",
  "manifest_version": 3,
  "name": "9–5 Reset",
  "version": "1.0.0",
  "description": "Calendar-aware micro-break reminders — short stretch and energy resets that fit the actual gaps in your workday.",
  "permissions": ["identity", "notifications", "alarms", "storage"],
  "host_permissions": ["https://www.googleapis.com/*", "https://dwjygnxecubtsxnelxpz.supabase.co/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
